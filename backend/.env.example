# Esempio configurazione locale - copia in .env e modifica.

# --- Database SQL (Azure SQL) ---
SQL_SERVER=tuoserver.database.windows.net
SQL_DATABASE=sailing
SQL_USER=sailingadmin
SQL_PASSWORD=YourStrongPwd!12345

# --- CORS ---
# Origini autorizzate per CORS (separate da virgola)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

# --- Admin ---
# Token segreto per creare barche via API admin (lascia vuoto per disabilitare)
ADMIN_TOKEN=

# --- Azure Blob Storage ---
# Connection string completa dell'account "sailingapp" (presa da Portal Azure
# > Storage Account > Access Keys). Necessaria per upload polar/waypoints,
# upload tracce e generazione SAS URL.
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=sailingapp;AccountKey=...;EndpointSuffix=core.windows.net

# Container blob per i tre tipi di dati. Tutti dentro l'account "sailingapp",
# con sotto-cartella per boat_id (es. polars/soar/polar.json).
# Default uguali ai nomi gia' creati su Azure; cambia solo se rinomini i container.
AZURE_BLOB_CONTAINER_POLARS=polars
AZURE_BLOB_CONTAINER_WAYPOINTS=waypoints
AZURE_BLOB_CONTAINER_TRACKS=tracks

# --- Azure Event Hubs (live streaming dal tablet al portale) ---
# Connection string del namespace Event Hubs. La policy "tablet-sender" e' usata
# dal tablet per pubblicare. Per il backend conviene una policy separata con
# permesso LISTEN soltanto (es. "portal-listener"). Per ora se non hai ancora
# creato la listener policy, puoi riusare la sender (sconsigliato in prod).
#
# IMPORTANTE: in produzione tieni queste credenziali SOLO in Azure App Settings
# (set-env.ps1), MAI committate. Ruota la chiave su Azure se viene esposta.
EVENTHUB_CONNECTION_STRING=Endpoint=sb://sailing-eventhubs.servicebus.windows.net/;SharedAccessKeyName=portal-listener;SharedAccessKey=...

# Nome dell'Event Hub (entity path) dentro il namespace.
EVENTHUB_NAME=sailing-eventhubs

# Consumer group: su Azure crea un consumer group dedicato (es. "portal-live")
# per non litigare sugli offset con altri consumer. Default: $Default.
EVENTHUB_CONSUMER_GROUP=$Default

# Heartbeat SSE: il backend manda un commento ogni N secondi per tenere
# viva la connessione attraverso proxy/load balancer Azure.
SSE_HEARTBEAT_SECONDS=15
